{
  "name": "novyra-cdk",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "novyra-cdk": "bin/app.js"
  },
  "scripts": {
    "build":   "tsc",
    "watch":   "tsc -w",
    "cdk":     "cdk",
    "synth":   "cdk synth",
    "deploy:dev":    "STAGE=dev  cdk deploy --require-approval never",
    "deploy:prod":   "STAGE=prod cdk deploy --require-approval any-change",
    "diff":    "cdk diff",
    "destroy": "cdk destroy"
  },
  "devDependencies": {
    "@types/node":           "^20.0.0",
    "aws-cdk":               "^2.130.0",
    "source-map-support":    "^0.5.21",
    "typescript":            "^5.4.0"
  },
  "dependencies": {
    "aws-cdk-lib":           "^2.130.0",
    "constructs":            "^10.3.0"
  }
}
