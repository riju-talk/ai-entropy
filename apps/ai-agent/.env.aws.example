# Entropy AI Engine — AWS Environment Variables
# Copy to .env.aws and fill in your values before deploying.

# AWS Credentials (set via IAM role in Lambda; only needed for local dev)
AWS_REGION=ap-northeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Amazon Bedrock
AI_PROVIDER=bedrock
BEDROCK_CLAUDE_MODEL=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_TITAN_EMBED=amazon.titan-embed-text-v2:0

# S3
S3_BUCKET_NAME=entropy-documents-dev-<ACCOUNT_ID>
S3_PRESIGN_EXPIRY_SECS=3600

# RDS PostgreSQL
DATABASE_URL=postgresql://entropy_admin:<PASSWORD>@<RDS_HOST>:5432/entropy

# Neo4j
NEO4J_URI=bolt://<HOST>:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# Redis
REDIS_HOST=<REDIS_HOST>
REDIS_PORT=6379
REDIS_PASSWORD=

# Gateway Proxy Token
AI_BACKEND_TOKEN=

# LLM Settings
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2048

# JWT
JWT_SECRET_KEY=<generate-secure-random-key>
JWT_ALGORITHM=HS256
